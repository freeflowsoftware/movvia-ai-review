{
  "$schema": "https://opencode.ai/config.json",
  "model": "llm/google/gemini-2.5-flash-lite",
  "small_model": "llm/google/gemini-2.5-flash-lite",
  "provider": {
    "llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLM OpenAI-compatible (BYOK via LLM_BASE_URL/LLM_API_KEY)",
      "options": {
        "baseURL": "{env:LLM_BASE_URL}",
        "apiKey": "{env:LLM_API_KEY}"
      },
      "models": {
        "google/gemini-2.5-flash-lite": {
          "name": "Gemini 2.5 Flash-Lite (via OpenRouter, default do piloto)"
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (via OpenRouter)"
        }
      }
    }
  }
}
