{
  "$schema": "https://opencode.ai/config.json",
  "model": "gemini/gemini-flash-lite",
  "small_model": "gemini/gemini-flash-lite",
  "provider": {
    "gemini": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLM OpenAI-compatible (Gemini Flash-Lite default)",
      "options": {
        "baseURL": "{env:LLM_BASE_URL}",
        "apiKey": "{env:LLM_API_KEY}"
      },
      "models": {
        "gemini-flash-lite": {
          "name": "Gemini Flash-Lite (OpenAI-compat)"
        }
      }
    }
  }
}
